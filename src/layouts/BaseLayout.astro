---
const { title = "Matteo Curcio", description = "Sito personale" } = Astro.props;

const pathname = Astro.url.pathname;

function isActive(path: string) {
  if (path === "/") return pathname === "/";
  return pathname === path || pathname.startsWith(path + "/");
}
---

<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --bg: #EEF2F7;
        --panel: #FFFFFF;
        --card: #F8FAFC;
        --text: #162033;
        --muted: #5F6B7F;
        --border: #D9E1EC;
        --accent: #C78925;
        --accent-soft: #F3E0BA;
        --accent-dark: #24324A;
        --shadow: 0 10px 26px rgba(22, 32, 51, 0.08);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --max-width: 1140px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        color: var(--text);
        background: var(--bg);
      }

      a {
        color: inherit;
      }

      .site-header {
        padding: 18px 20px 0;
      }

      .header-shell {
        max-width: var(--max-width);
        margin: 0 auto;
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow);
        padding: 14px 18px;
      }

      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        flex-wrap: wrap;
      }

      .brand {
        text-decoration: none;
        font-size: 0.96rem;
        font-weight: 800;
        letter-spacing: 0.5px;
        color: var(--text);
      }

      nav {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .nav-link {
      text-decoration: none;
      color: var(--muted);
      font-size: 0.86rem;
      font-weight: 700;
      padding: 8px 13px;
      border-radius: 12px;
      transition:
        background-color 0.2s ease,
        color 0.2s ease,
        transform 0.2s ease,
        box-shadow 0.2s ease;
    }

      .nav-link:hover {
      background: var(--bg);
      color: var(--text);
      transform: translateY(-2px);
      box-shadow: 0 8px 18px rgba(22, 32, 51, 0.08);
    }

      .nav-link.active {
        background: var(--accent);
        color: white;
      }

      .nav-link.active:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(199, 137, 37, 0.22);
    }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 28px 20px 64px;
      }

      .box {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 36px;
      box-shadow: var(--shadow);
     }

     .page-link,
    .page-link:visited {
      color: inherit;
      text-decoration: none;
    }

    .page-link * {
      text-decoration: none;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 28px;
      box-shadow: var(--shadow);
      }
      .card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius-md);
        padding: 22px;
        box-shadow: var(--shadow);
      }

      .page-link {
        display: block;
        text-decoration: none;
        height: 100%;
      }

      .page-link .card {
        height: 100%;
        transition:
          transform 0.22s ease,
          box-shadow 0.22s ease,
          border-color 0.22s ease,
          background-color 0.22s ease;
      }

      .page-link:hover .card {
        transform: translateY(-6px);
        border-color: rgba(199, 137, 37, 0.38);
        background: #ffffff;
        box-shadow: 0 20px 38px rgba(22, 32, 51, 0.14);
      }

      .section-title {
        font-size: 1.9rem;
        margin: 0 0 10px;
      }

      .section-text {
        margin: 0;
        color: var(--muted);
        line-height: 1.75;
      }

      h1, h2, h3 {
        color: var(--text);
      }

      footer {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 20px 40px;
        text-align: center;
        color: var(--muted);
      }

      @media (max-width: 700px) {
      .box,
      .card {
        padding: 24px;
      }

      .section-title {
        font-size: 1.55rem;
      }

      .header-shell {
        padding: 12px 14px;
      }
    }
    </style>
  </head>

  <body>
    <header class="site-header">
      <div class="header-shell">
        <div class="header-inner">
          <a class="brand" href="/">Matteo Curcio</a>

          <nav>
            <a class={`nav-link ${isActive("/") ? "active" : ""}`} href="/">Home</a>
            <a class={`nav-link ${isActive("/blog") ? "active" : ""}`} href="/blog">Blog</a>
            <a class={`nav-link ${isActive("/progetti") ? "active" : ""}`} href="/progetti">Progetti</a>
            <a class={`nav-link ${isActive("/foto") ? "active" : ""}`} href="/foto">Foto</a>
            <a class={`nav-link ${isActive("/contatti") ? "active" : ""}`} href="/contatti">Contatti</a>
          </nav>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      © 2026 Matteo Curcio · Sito personale
    </footer>
  </body>
</html>