---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Matteo Curcio | Home"
  description="Sito personale con blog, progetti e foto"
>
  <section class="box">
    <h1>Ciao, questo è il mio sito personale</h1>
    <p>
      Qui raccoglierò articoli, progetti, fotografie e aggiornamenti sul mio lavoro.
    </p>
  </section>

  <section class="cards">
    <div class="card">
      <h2>Blog</h2>
      <p>Articoli, idee e approfondimenti.</p>
    </div>

    <div class="card">
      <h2>Progetti</h2>
      <p>Una raccolta dei miei lavori tecnici e personali.</p>
    </div>

    <div class="card">
      <h2>Foto</h2>
      <p>Gallerie e contenuti visivi.</p>
    </div>
  </section>
</BaseLayout>