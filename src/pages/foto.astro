---
import BaseLayout from "../layouts/BaseLayout.astro";

const photos = [
  "/images/foto/foto1.jpg",
  "/images/foto/foto2.jpg",
  "/images/foto/foto3.jpg",
];
---

<BaseLayout
  title="Matteo Curcio | Foto"
  description="Galleria fotografica"
>
  <section class="box">
    <h1>Foto</h1>
    <p>Una piccola galleria iniziale.</p>
  </section>

  <section class="cards">
    {photos.map((photo) => (
      <div class="card">
        <img src={photo} alt="Foto galleria" style="width: 100%; border-radius: 12px;" />
      </div>
    ))}
  </section>
</BaseLayout>