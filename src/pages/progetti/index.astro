---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Matteo Curcio | Progetti"
  description="Portfolio dei progetti"
>
  <section class="box intro-box">
    <h1>Progetti</h1>
    <p>
      Una selezione dei miei lavori, con descrizione, stato di avanzamento e tecnologie principali.
    </p>
  </section>

  <section class="cards">
    {projects.map((project) => (
      <a class="page-link" href={`/progetti/${project.id}/`}>
        <article class="card project-card">
          {project.data.cover && (
            <img
              src={project.data.cover}
              alt={project.data.title}
              class="project-cover"
            />
          )}

          <div class="project-content">
            <div class="project-meta">
              <span class={`status ${project.data.status === "Concluso" ? "status-done" : "status-ongoing"}`}>
                {project.data.status}
              </span>
              <span class="date">{project.data.pubDate.toLocaleDateString("it-IT")}</span>
            </div>

            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>

            <div class="tags">
              {project.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .intro-box p {
    margin: 0;
    color: #5f6b7f;
    line-height: 1.7;
  }

  .project-card {
    overflow: hidden;
    padding: 0;
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease,
      border-color 0.24s ease,
      background-color 0.24s ease;
  }

  .project-cover {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid #e3e8f2;
    transition:
      transform 0.35s ease,
      filter 0.3s ease;
  }

  .project-content {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .status {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    transition:
      transform 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .status.done {
    background: #e8f7ee;
    color: #157347;
  }

  .status.ongoing {
    background: #eef4ff;
    color: #24324a;
  }

  .date {
    color: #6b7280;
    font-size: 0.92rem;
  }

  .project-content h2 {
    margin: 0;
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .project-content p {
    margin: 0;
    color: #5f6b7f;
    line-height: 1.7;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: auto;
  }

  .tag {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 999px;
    background: #f3f6fb;
    color: #4b5563;
    font-size: 0.82rem;
    font-weight: 600;
    transition:
      background-color 0.2s ease,
      color 0.2s ease;
  }

  .page-link:hover .project-card {
    transform: translateY(-7px);
    border-color: rgba(199, 137, 37, 0.4);
    background: #ffffff;
    box-shadow: 0 22px 40px rgba(22, 32, 51, 0.15);
  }

  .page-link:hover .project-cover {
    transform: scale(1.04);
    filter: saturate(1.03);
  }

  .page-link:hover .project-content h2 {
    color: #24324a;
  }

  .page-link:hover .status.ongoing {
    background: #f3e0ba;
    color: #24324a;
  }

  .page-link:hover .status.done {
    transform: translateY(-1px);
  }

  .page-link:hover .tag {
    background: #eef4ff;
    color: #24324a;
  }
</style>