---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const projects = (await getCollection("projects"))
  .filter((project) => !project.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Matteo Curcio | Progetti"
  description="Portfolio dei progetti"
>
  <section class="box intro-box">
    <h1>Progetti</h1>
    <p>
      Una selezione dei miei lavori, con descrizione, stato di avanzamento e tecnologie principali.
    </p>
  </section>

  <section class="cards">
    {projects.map((project) => (
      <a class="page-link" href={`/progetti/${project.id}/`}>
        <article class="card project-card">
          {project.data.cover && (
            <img
              src={project.data.cover}
              alt={project.data.title}
              class="project-cover"
            />
          )}

          <div class="project-content">
            <div class="project-meta">
              <span class={`status ${project.data.status === "Concluso" ? "status-done" : "status-ongoing"}`}>
                {project.data.status}
              </span>
              <span class="date">{project.data.pubDate.toLocaleDateString("it-IT")}</span>
            </div>

            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>

            <div class="tags">
              {project.data.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      </a>
    ))}
  </section>
</BaseLayout>

<style>
  .intro-box p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .project-card {
    overflow: hidden;
    padding: 0;
  }

  .project-cover {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
    border-bottom: 1px solid var(--border);
  }

  .project-content {
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .project-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .project-content h2 {
    margin: 0;
    line-height: 1.3;
    color: var(--navy);
  }

  .project-content p {
    margin: 0;
    color: var(--muted);
    line-height: 1.75;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: auto;
  }
</style>