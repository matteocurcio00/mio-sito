---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const projects = await getCollection("projects", ({ data }) => !data.draft);

  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={`Matteo Curcio | ${project.data.title}`}
  description={project.data.description}
>
  <article class="box project-detail">
    {project.data.cover && (
      <img
        src={project.data.cover}
        alt={project.data.title}
        class="detail-cover"
      />
    )}

    <div class="detail-header">
      <div class="meta-row">
        <span class={`status ${project.data.status === "Concluso" ? "done" : "ongoing"}`}>
          {project.data.status}
        </span>
        <span class="date">{project.data.pubDate.toLocaleDateString("it-IT")}</span>
      </div>

      <h1>{project.data.title}</h1>
      <p class="description">{project.data.description}</p>

      <div class="tags">
        {project.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    </div>

    <hr />

    <div class="project-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .project-detail {
    max-width: 920px;
    margin: 0 auto;
    overflow: hidden;
  }

  .detail-cover {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    display: block;
    border-radius: 16px;
    margin-bottom: 26px;
  }

  .detail-header h1 {
    margin-bottom: 12px;
  }

  .meta-row {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 18px;
  }

  .status {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .status.done {
    background: #e8f7ee;
    color: #157347;
  }

  .status.ongoing {
    background: #eef4ff;
    color: #1d4ed8;
  }

  .date {
    color: #6b7280;
  }

  .description {
    color: #5f6b85;
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    margin-top: 16px;
  }

  .tag {
    display: inline-block;
    padding: 6px 10px;
    border-radius: 999px;
    background: #f3f6fb;
    color: #4b5563;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .project-content {
    line-height: 1.8;
  }
</style>